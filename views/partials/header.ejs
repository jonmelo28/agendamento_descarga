<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof titulo !== 'undefined' ? titulo + ' — ' : '' %>Agendamento de Descarga</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <h1>📦 Agendamento</h1>
      <span>Sistema de Descarga</span>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Operações</div>
      <a href="/agendamentos" class="<%= typeof activePage !== 'undefined' && activePage === 'agendamentos' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Agendamentos
      </a>
      <a href="/agendamentos/novo" class="<%= typeof activePage !== 'undefined' && activePage === 'agendamentos-novo' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Novo Agendamento
      </a>
      <a href="/usuarios/<%= typeof usuario !== 'undefined' && usuario ? usuario.id : '' %>/editar">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Meu Perfil
      </a>

      <% if (typeof usuario !== 'undefined' && usuario && usuario.perfil === 'admin') { %>
      <div class="nav-section">Administração</div>
      <a href="/usuarios" class="<%= typeof activePage !== 'undefined' && activePage === 'usuarios' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Usuários
      </a>
      <a href="/metricas" class="<%= typeof activePage !== 'undefined' && activePage === 'metricas' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Métricas / Capacidade
      </a>
      <div class="nav-section">Bot Telegram</div>
      <a href="/bot-usuarios" class="<%= typeof activePage !== 'undefined' && activePage === 'bot-usuarios' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Usuários do Bot
      </a>
      <a href="/bot-rotas" class="<%= typeof activePage !== 'undefined' && activePage === 'bot-rotas' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
        Rotas / Menu do Bot
      </a>
      <% } %>
    </nav>
    <div class="sidebar-footer">
      <span class="user-name"><%= typeof usuario !== 'undefined' && usuario ? usuario.nome : '' %></span>
      <span class="user-role"><%= typeof usuario !== 'undefined' && usuario ? usuario.perfil : '' %></span>
      <a href="/logout" class="logout-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sair
      </a>
    </div>
  </aside>
  <main class="main-content">
    <div class="topbar">
      <div class="topbar-title"><%= typeof titulo !== 'undefined' ? titulo : 'Painel' %></div>
      <div class="topbar-actions">
        <span style="font-size:.78rem;color:#64748b">Olá, <%= typeof usuario !== 'undefined' && usuario ? usuario.nome.split(' ')[0] : '' %></span>
      </div>
    </div>
    <div class="page-content">
