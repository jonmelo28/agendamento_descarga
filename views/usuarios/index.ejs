<%
  titulo = 'Usuários do Sistema';
  activePage = 'usuarios';
%>
<%- include('../partials/header') %>

<% if (sucesso) { %><div class="alert alert-success">✓ <%= sucesso %></div><% } %>
<% if (erro)    { %><div class="alert alert-danger">⚠ <%= erro %></div><% } %>

<div class="card">
  <div class="card-header">
    <span class="card-title">Usuários (<%= usuarios.length %>)</span>
    <a href="/usuarios/novo" class="btn btn-primary btn-sm">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Novo Usuário
    </a>
  </div>

  <% if (usuarios.length === 0) { %>
    <div class="empty-state"><p>Nenhum usuário cadastrado.</p></div>
  <% } else { %>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Nome</th>
          <th>E-mail</th>
          <th>Perfil</th>
          <th>Status</th>
          <th>Cadastrado em</th>
          <th style="text-align:right">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% usuarios.forEach(u => { %>
        <tr>
          <td><span class="mono" style="color:#64748b"><%= u.id %></span></td>
          <td><strong><%= u.nome %></strong></td>
          <td><%= u.email %></td>
          <td>
            <span class="badge <%= u.perfil === 'admin' ? 'badge-info' : 'badge-warning' %>">
              <%= u.perfil === 'admin' ? '⭐ Admin' : '👤 Operador' %>
            </span>
          </td>
          <td>
            <span class="badge <%= u.ativo ? 'badge-success' : 'badge-danger' %>">
              <%= u.ativo ? 'Ativo' : 'Inativo' %>
            </span>
          </td>
          <td style="font-size:.78rem;color:#64748b">
            <%= new Date(u.criado_em).toLocaleDateString('pt-BR') %>
          </td>
          <td>
            <div style="display:flex;gap:5px;justify-content:flex-end">
              <a href="/usuarios/<%= u.id %>/editar" class="btn btn-warning btn-sm btn-icon" title="Editar">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:13px;height:13px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
              </a>
              <% if (u.id !== usuario.id) { %>
              <button class="btn btn-danger btn-sm btn-icon" title="Excluir"
                onclick="confirmarExclusaoUser(<%= u.id %>, '<%= u.nome.replace(/'/g, "\\'") %>')">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:13px;height:13px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
              <% } %>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Modal Excluir -->
<div class="modal-overlay" id="modalExcluirUser">
  <div class="modal">
    <div class="modal-title">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:20px;height:20px;color:#dc2626"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      Confirmar Exclusão
    </div>
    <p id="modalExcluirUserText" style="font-size:.85rem;color:#64748b;margin-bottom:16px"></p>
    <form id="formExcluirUser" method="POST">
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" data-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-danger">Excluir</button>
      </div>
    </form>
  </div>
</div>

<script>
  function confirmarExclusaoUser(id, nome) {
    document.getElementById('formExcluirUser').action = `/usuarios/${id}/excluir`;
    document.getElementById('modalExcluirUserText').textContent = `Tem certeza que deseja excluir o usuário "${nome}"?`;
    document.getElementById('modalExcluirUser').classList.add('active');
  }
</script>

<%- include('../partials/footer') %>
