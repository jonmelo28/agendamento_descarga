<%
  titulo = 'Usuários do Bot Telegram';
  activePage = 'bot-usuarios';
%>
<%- include('../partials/header') %>

<% if (sucesso) { %><div class="alert alert-success">✓ <%= sucesso %></div><% } %>
<% if (erro)    { %><div class="alert alert-danger">⚠ <%= erro %></div><% } %>

<div class="card">
  <div class="card-header">
    <span class="card-title">Usuários Autorizados do Bot (<%= botUsuarios.length %>)</span>
    <a href="/bot-usuarios/novo" class="btn btn-primary btn-sm">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Adicionar
    </a>
  </div>

  <% if (botUsuarios.length === 0) { %>
    <div class="empty-state">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
      <p>Nenhum usuário do bot cadastrado.</p>
    </div>
  <% } else { %>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>Telegram ID</th>
          <th>Username</th>
          <th>Permissões</th>
          <th>Status</th>
          <th>Cadastrado em</th>
          <th style="text-align:right">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% botUsuarios.forEach(bu => { %>
        <tr>
          <td><strong><%= bu.nome %></strong></td>
          <td><span class="mono"><%= bu.telegram_id %></span></td>
          <td><%= bu.username ? '@' + bu.username : '—' %></td>
          <td>
            <% const perms = Array.isArray(bu.permissoes) ? bu.permissoes : []; %>
            <% if (perms.length === 0) { %>
              <span style="font-size:.75rem;color:#0ea5e9;font-weight:600">Todas</span>
            <% } else { %>
              <span class="badge" style="background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;font-size:.72rem">
                🔒 <%= perms.length %> rota<%= perms.length !== 1 ? 's' : '' %>
              </span>
            <% } %>
          </td>
          <td>
            <span class="badge <%= bu.ativo ? 'badge-success' : 'badge-danger' %>">
              <%= bu.ativo ? 'Autorizado' : 'Bloqueado' %>
            </span>
          </td>
          <td style="font-size:.78rem;color:#64748b">
            <%= new Date(bu.criado_em).toLocaleDateString('pt-BR') %>
          </td>
          <td>
            <div style="display:flex;gap:5px;justify-content:flex-end">
              <a href="/bot-usuarios/<%= bu.id %>/editar" class="btn btn-warning btn-sm btn-icon" title="Editar">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:13px;height:13px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
              </a>
              <button class="btn btn-danger btn-sm btn-icon" title="Excluir"
                onclick="confirmarExclusaoBot(<%= bu.id %>, '<%= bu.nome.replace(/'/g, "\\'") %>')">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:13px;height:13px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Modal Excluir -->
<div class="modal-overlay" id="modalExcluirBot">
  <div class="modal">
    <div class="modal-title" style="color:#dc2626">⚠ Confirmar Exclusão</div>
    <p id="modalExcluirBotText" style="font-size:.85rem;color:#64748b;margin-bottom:16px"></p>
    <form id="formExcluirBot" method="POST">
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" data-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-danger">Excluir</button>
      </div>
    </form>
  </div>
</div>

<script>
  function confirmarExclusaoBot(id, nome) {
    document.getElementById('formExcluirBot').action = `/bot-usuarios/${id}/excluir`;
    document.getElementById('modalExcluirBotText').textContent = `Remover "${nome}" dos usuários autorizados do bot?`;
    document.getElementById('modalExcluirBot').classList.add('active');
  }
</script>

<%- include('../partials/footer') %>
